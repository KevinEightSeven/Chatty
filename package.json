{
  "name": "chatty",
  "version": "1.3.4",
  "description": "Twitch Chat Client — inspired by Chatterino",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --ozone-platform-hint=auto",
    "dev": "electron . --dev --ozone-platform-hint=auto",
    "dist": "electron-builder --win --mac --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "twitch",
    "chat",
    "gaming",
    "electron"
  ],
  "author": {
    "name": "sempd",
    "email": "sempd@users.noreply.github.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.sempd.chatty",
    "productName": "Chatty",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis",
      "artifactName": "Chatty-Setup.${ext}",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "mac": {
      "target": "dmg",
      "artifactName": "Chatty.${ext}",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "pacman"],
      "artifactName": "Chatty.${ext}",
      "category": "Chat"
    },
    "pacman": {
      "depends": ["gtk3", "libnotify", "nss", "libxss", "libxtst", "xdg-utils", "at-spi2-core", "util-linux-libs"]
    }
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "ws": "^8.18.0"
  }
}
